{
  "name": "scanlab",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "translate": "i18n-cloud-translator",
    "serve": "vite",
    "build": "vite build && rimraf dist/assets/*.map",
    "preview": "vite preview --port 8080",
    "lint": "eslint src --fix",
    "lint-vue": "eslint src --fix --quiet --ext .js,.vue --rule \"no-unused-vars: off, vue/valid-v-model: off, vue-i18n/no-raw-text: off\"",
    "up": "yarn upgrade-interactive --latest",
    "bashvetmr": "heroku run -a scanlab-vet-api bash",
    "cruise": "yarn install && yarn serve"
  },
